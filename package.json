{
  "name": "player-data-api",
  "version": "1.0.0",
  "description": "Licensable Player Data API for fantasy baseball draft kit",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "import-csv": "node scripts/csv-to-players.js",
    "import-mlb": "node scripts/fetch-mlb-data.js",
    "import-mlb-db": "node src/jobs/ingestPlayerMetadata.js",
    "import-injuries": "node src/jobs/ingestInjuries.js",
    "import-depth-charts": "node src/jobs/ingestDepthCharts.js",
    "import-transactions": "node src/jobs/ingestTransactions.js",
    "import-stats": "node src/jobs/ingestStats.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["src/**/*.js"]
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "jest": "^30.3.0"
  }
}
