# Server
PORT=4001

# License: comma-separated keys or single key (API_LICENSE_KEY takes precedence)
API_LICENSE_KEY=your-secret-key
# VALID_API_KEYS=key1,key2,key3

# CORS: allowed origin for draft kit (e.g. http://localhost:3000)
ALLOWED_ORIGIN=http://localhost:3000

# Database: path to SQLite file (relative to project root)
DB_PATH=data/players.db

# balldontlie MLB API key (required for import-mlb and import-mlb-db)
BALLDONTLIE_API_KEY=your-balldontlie-api-key
