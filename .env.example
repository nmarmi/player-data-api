# ── Server ────────────────────────────────────────────────────────────────────
PORT=4001
NODE_ENV=development

# ── Auth (US-8.5) ─────────────────────────────────────────────────────────────
# License key set: a single key takes precedence; otherwise comma-separated.
API_LICENSE_KEY=your-secret-key
# VALID_API_KEYS=key1,key2,key3
# Optional separate admin key for POST /admin/refresh; falls back to the
# license key set when unset, so single-key deployments don't need two secrets.
# ADMIN_API_KEY=your-admin-secret

# Per-key rate limit applied to all licensed /api/v1/* routes (US-8.5).
# /health is exempt. Returns 429 with Retry-After when exceeded.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_PER_WINDOW=600
# Set to "true" in tests where you want to bypass rate limiting entirely.
# RATE_LIMIT_DISABLED=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Allowed origin for the Draft Kit (e.g. http://localhost:3000). Use * only in
# trusted dev environments — production should pin the origin.
ALLOWED_ORIGIN=http://localhost:3000

# ── Database (US-3.1) ─────────────────────────────────────────────────────────
# Path to SQLite file (relative to project root).
DB_PATH=data/players.db

# ── Legacy API deprecation (US-2.8) ───────────────────────────────────────────
# Sunset date for the unversioned /players, /usage, /health, /license, /admin
# routes. RFC 7231 IMF-fixdate format. Update when the cutover date changes.
LEGACY_API_SUNSET=Wed, 31 Dec 2026 23:59:59 GMT
# Link header sent on legacy responses pointing at the migration doc.
LEGACY_API_MIGRATION_LINK=</docs/migration-v1.md>; rel="deprecation"

# ── Scheduler (US-4.6) ────────────────────────────────────────────────────────
# Master toggle. Set to false to disable all background ingestion (useful for
# tests, one-shot CLI runs, and CI).
SCHEDULER_ENABLED=true
# How often static data (player_metadata, player_stats) refreshes.
STATIC_INTERVAL_HOURS=24
# How often slow-changing data (depth_charts, transactions) refreshes.
SLOW_INTERVAL_HOURS=6
# How often the injuries job ticks (only inside ACTIVE_HOURS).
INJURY_INTERVAL_MINUTES=30
# Active-hours window for the injuries job (local time, 0–23 inclusive).
ACTIVE_HOURS_START=10
ACTIVE_HOURS_END=23

# ── Logging (US-8.2) ──────────────────────────────────────────────────────────
# Verbosity: debug | info | warn | error.
LOG_LEVEL=info
# Set to "true" for human-readable single-line output (dev only). Default is
# JSON, one entry per line, suitable for log aggregators.
LOG_PRETTY=false

# ── MLB Stats API ─────────────────────────────────────────────────────────────
# No API key required. The ingestion jobs call statsapi.mlb.com directly.

# ── Developer Portal (Epic 10) ────────────────────────────────────────────────
# HMAC secret for signing session cookies on /developer-portal. If unset, a
# random per-process secret is used and dev sessions don't survive restart.
# REQUIRED in production.
SESSION_SECRET=

# Bootstrap admin developer account, seeded on first start. In production the
# seeder REFUSES to run when ADMIN_PASSWORD is missing or set to "changeme".
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=changeme

# Set to "true" when running behind a reverse proxy (Render, Vercel rewrites,
# any load balancer) so requireLicense reads the real client IP from
# X-Forwarded-For for IP-whitelist checks (US-10.5).
TRUST_PROXY=false

# ── Valuation Engine — Epic 11 inputs ─────────────────────────────────────────
# Active projection source for valuations (steamer | zips | manual). Used as
# the default when leagueSettings doesn't override and as the import script's
# default --source value.
VALUATION_PROJECTION_SOURCE=steamer

# Override age-multiplier curve as a JSON object mapping age to multiplier.
# Anchor points are linearly interpolated. Example:
# VALUATION_AGE_CURVE={"22":1.05,"24":1.0,"30":0.94,"35":0.85}
# Default lives in src/services/valuationEngine.js DEFAULTS.ageCurve.
# VALUATION_AGE_CURVE=

# Override injury-discount table as a JSON object. Merged over the defaults
# (il_10:0.95, il_15:0.93, il_60:0.6, dtd:0.97, minors:0, dfa:0). Example:
# VALUATION_INJURY_DISCOUNTS={"il_60":0.5,"out":0.4}
# VALUATION_INJURY_DISCOUNTS=

# Override depth-chart multiplier curve. Defaults: 1:1.0, 2:0.9, 3:0.7, 4+:0.4,
# uncharted:0.5. Example:
# VALUATION_DEPTH_CURVE={"3":0.6,"4+":0.3}
# VALUATION_DEPTH_CURVE=
